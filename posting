    posting_date_str = today.strftime("%Y%m%d")
    today_str = posting_date_str
    yesterday=yesterday.strftime("%Y-%m-%d")
    today= today.strftime("%Y-%m-%d")
    PROCESS_ID= getattr(constants,"P_L_POSTING_PIPELINE_ID", 14) 
    RUN_ID = get_run_id(spark,today,PROCESS_ID) 
    if(RUN_ID >1):
        wipe_etl_transactions_sql =f"""()t"""
    logger = setup_logger("PL_POSTING", RUN_ID , posting_date_str)
     
    logger.info(f"=== Using current date for POST_DATE: {posting_date_str} ===")
    logger.info(f"RUN_ID as : {RUN_ID}")

    logger.info(f"Fetched oracle properties SUCCESFULLY :)")
    
    hdfs_paths = paths_for_read("glif",today,today_str) 
    GL_DATALAKE_PATH = hdfs_paths["GL_DATALAKE_PATH"]
    oracle_properties=get_oracle_properties()

    oracle_url = oracle_properties["url"]
    oracle_user = oracle_properties["user"]
    oracle_password = oracle_properties["password"]
    oracle_driver = oracle_properties["driver"]

    process_run_id = sys.argv[1] if len(sys.argv) > 1 else get_process_run_id(spark,PROCESS_ID,today)

    # log_etl(spark, process_run_id, "PL_Posting",1)
    try:
        load_balance_sql = f"""(select * from P_L_TRANSFER_BALANCE) t1"""
        load_transactions_sql = f"""(select CGL,CURRENCY,BRANCH_CODE,NARRATION,SOURCE_FLAG,BATCH_ID,DEBIT_AMOUNT,CREDIT_AMOUNT,TRANSACTION_COUNT,JOURNAL_ID,TRANSACTION_DATE from P_L_TRANSFER_TRANSACTIONS) t1"""

# ---------------------------- Load Transactions ---------------------------------------------------
        # log_etl(spark, process_run_id, "PL_Posting_Loading_Transactions",1)   
        try:
            load_transactions = read_oracle(spark,load_transactions_sql)
            # log_etl(spark, process_run_id, "PL_Posting_Loading_Transactions",2)
        except Exception as e:
            print(f"Error {e} while loading data from Transactions Table") 
            # log_etl(spark, process_run_id, "PL_Posting_Loading_Transactions",3, f"Failed While loading Transactions Reason: {e}.")  
# ------------------------------ Posting Balances on Oracle -------------------------------------------------            
        # log_etl(spark, process_run_id, "PL_Posting_Balance",1)
        try:
            conn = spark._sc._gateway.jvm.java.sql.DriverManager.getConnection(oracle_url,oracle_user,oracle_password)
            merge_sql = f"""
                        MERGE INTO GL_BALANCE_TEST  target
                        USING  P_L_TRANSFER_BALANCE  source
                        ON (
                              target.cgl = source.cgl
                          AND target.currency = source.currency
                          AND target.branch_code = source.branch_code
                          AND target.balance_date = source.balance_date
                        )
                        WHEN MATCHED THEN
                        UPDATE SET
                           target.balance = NVL(target.balance,0) + source.balance , target.inr_balance = NVL(target.balance,0) + source.balance 
                        WHEN NOT MATCHED THEN
                        INSERT (
                           cgl,
                           currency,
                           branch_code,
                           balance,
                           inr_balance,
                           balance_date
                        )
                        VALUES (
                           source.cgl,
                           source.currency,
                           source.branch_code,
                           source.balance,
                           source.balance,
                           source.balance_date
                        )
                        """  
            conn.setAutoCommit(False)             
            statement = conn.createStatement()
            print("stmt")
            statement.execute(merge_sql)
            print("stmt exec")
            
            conn.commit()
            print("comm comit")
            statement.close()
            print("stmt close")
            conn.close()
            print("conn close")
            print("MERGE executed successfully")              
            # log_etl(spark, process_run_id, "PL_Posting_Balance",2)  
        except Exception as e:    
            print(f"Error {e} while writing to BALANCE oracle table.")

            # log_etl(spark, process_run_id, "PL_Posting_Balance",3, f"Failed While posting balances Reason: {e}.") 

# ------------------------------- Posting Balances on Data-Lake------------------------------------------------            
        # log_etl(spark, process_run_id, "PL_Posting_Data_Datalake",1)      
        try:             
            source_df = read_oracle(spark, load_balance_sql)
            source_df = source_df.select(
               concat(col("BRANCH_CODE"),col("CURRENCY"),col("CGL")).alias("glcc"),
               col("BALANCE").alias("balance"),
               col("BALANCE_DATE").alias("balance_date")
            )
            source_df.show(10,False)
            
            # delta_table = DeltaTable.forPath(spark,GL_DATALAKE_PATH)
            delta_table = DeltaTable.forPath(
               spark,
               "hdfs://10.0.17.76:8020/data-lake/etl-testing/gl_balance" 
            )
            # GL_DATALAKE_PATH
            delta_table.alias("target").merge(
               source_df.alias("source"),
               """
               target.glcc = source.glcc
               AND target.BALANCE_DATE = source.balance_date
               """
            ).whenMatchedUpdate(
               set={
                   "closing_balance": "coalesce(target.closing_balance,0) + coalesce(source.balance,0)"
               }
            ).whenNotMatchedInsert(
               values={
                   "glcc": "source.glcc",
                   "closing_balance": "source.balance",
                   "BALANCE_DATE": "source.balance_date"
               }
            ).execute()
            # log_etl(spark, process_run_id, "PL_Posting_Data_Datalake",2, "Successfully posting to Balance Datalake")
        except Exception as e:    
            print(f"Error {e} while writing to Datalake.")
            # log_etl(spark, process_run_id, "PL_Posting_Data_Datalake",3, f"Failed While posting balances to datalake Reason: {e}.")
# --------------------------------Posting Transactions -----------------------------------------------
        # log_etl(spark, process_run_id, "PL_Posting_transactions",1)
        try:
            write_oracle(load_transactions, "GL_TRANSACTIONS_TEST")
            # log_etl(spark, process_run_id, "PL_Posting_transactions",2, "Successfully Transfered of Transactions")
        except Exception as e:    
            print(f"Error {e} while writing to TRANSACTIONS oracle Table.")
            # log_etl(spark, process_run_id, "PL_Posting_transactions",3, f"Failed While posting Transactions. Reason: {e}.")
        # log_etl(spark, process_run_id, "PL_Posting",2,"Profit and Loss Successfully Posted.")

    except Exception as e:
        print(f"Error {e} while posting Profit and Loss.")  
        # log_etl(spark, process_run_id, "PL_Posting",3,f"Failed While posting Profit and Loss. Reason {e}.")  

    spark.stop()




