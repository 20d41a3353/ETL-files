apiVersion: v1
kind: Pod
metadata:
  name: active
  namespace: uat-cbops1
spec:
  restartPolicy: Never
  containers:
  - name: spark-py
    image: h06vksharbor.corp.ad.sbi/cbops/etl:v100
    imagePullPolicy: Always
    # Resources must be defined so K8s doesn't kill the pod
    resources:
      requests:
        memory: "10Gi"
        cpu: "8"
      limits:
        memory: "12Gi"
        cpu: "10"
    command: ["/opt/spark/bin/spark-submit"]
    args:
      - "--master"
      - "local[*]"
      - "--name"
      - "active"
      # Allocate memory to the JVM (Spark Driver/Executor)
      - "--driver-memory"
      - "10g" 
      - "--executor-memory"
      - "10g"
      # Prevent "Result exceeds maxResultSize" errors
      - "--conf"
      - "spark.driver.maxResultSize=4g"
      # Paths to dependencies
      - "--jars"
      - "/app/Scripts/jars/ojdbc8.jar"
      - "/app/Scripts/active_hdfs.py"
