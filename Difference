                log_etl(spark, process_run_id, "GL_BALANCE_ORACLE_READING",3,"Error difference GL_BALANCE oracle reading")
                
            if(cbsdf==1):
                log_etl(spark, process_run_id, "CBS_DATALAKE_READING", 3, "Error In difference CBS Data loaded from datalake path ") 
            else:
                log_etl(spark, process_run_id, "CBS_BALANCE_ORACLE_READING",3, "Error In difference CBS_BALANCE oracle reading")
            if(prevDiff==1):
                log_etl(spark, process_run_id, "DIFFERENCE_DATALAKE_READING", 3, "Error In difference Data loading from datalake path ")
            else: 
                log_etl(spark, process_run_id, "DIFFERENCE_ORACLE_READING",3," eror in difference table oracle reading ")
            
            log_etl(spark, process_run_id, "CGL_MASTER_READING",3, "Error in Branch list loading")  
            log_etl(spark, process_run_id, "DIFFERENCE_DATALAKE_WRITING", 3, f"ETL step failed while difference data writing to datake")
            log_etl(spark, process_run_id, "difference_started",3,"Error in diffrence pipline")
            spark.stop()
        nested_summary = (
           final_df
           .groupBy("RECON_RUN_DATE","HEAD")
           .agg(          
                 count("*").alias("Total_no_of_entries"),
                 sum(when(col("type") == "New Entry", 1).otherwise(0)).alias("new entry"))
               ).alias("summary")
        
        summary = (
           nested_summary
           .groupBy("RECON_RUN_DATE")
           .agg(
               collect_list(
                   struct(
                       col("HEAD"),
                       col("Total_no_of_entries"),
                       col('new entry')
                   )
               ).alias("summary")
           )
        )
 
        nested_summary_json = summary.select(
           to_json(struct(col("RECON_RUN_DATE"),col("summary"))).alias("summary_json")
        )
        
        nested_summary_json.show(truncate=False)
        log_etl(spark, process_run_id, "difference_summarry",2,"Summary for diffrence", nested_summary_json ,0)
        log_etl(spark, process_run_id, "difference_started",2,"difference pipeline Completed.")
        logger.info("Difference pipeline completed")
        spark.stop()
 
    except Exception as e:
        print("ERROR during reconciliation: " , e)
        log_etl(spark, process_run_id, "difference_started",3,"Error in diffrence pipline")
        spark.stop()    
        sys.exit(1)
 
 
if __name__ == "__main__":
    main(sys.argv)
 
 
 
